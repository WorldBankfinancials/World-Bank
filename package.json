    "@typescript-eslint/parser": "^8.42.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "10.4.20",
    "drizzle-kit": "^0.18.1",
    "esbuild": "^0.25.9",
    "eslint": "^9.35.0",
    "eslint-plugin-react": "^7.37.5",
    "postcss": "8.4.47",
